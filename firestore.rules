rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, update: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(['displayName', 'email', 'photoURL', 'createdAt', 'lastLoginAt'])
        && request.resource.data.email is string;
      allow delete: if false;

      match /chats/{chatId} {
        allow read, delete: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['title', 'createdAt', 'updatedAt', 'lastMessagePreview'])
          && request.resource.data.title is string;
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'lastMessagePreview']);

        match /messages/{messageId} {
          allow read: if isOwner(uid);
          allow create: if isOwner(uid)
            && request.resource.data.keys().hasAll(['role', 'content', 'createdAt'])
            && request.resource.data.role in ['user', 'assistant']
            && request.resource.data.content is string;
          allow update, delete: if false;
        }
      }

      match /favorites/{itemId} {
        allow read, delete: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasAll(['topic', 'refId', 'savedAt'])
          && request.resource.data.topic in ['touristSpot', 'restaurant', 'accommodation', 'transportation', 'emergencyContact', 'faq'];
        allow update: if false;
      }
    }

    match /touristSpots/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /restaurants/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /accommodations/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /transportation/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /emergencyContacts/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /faqs/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
