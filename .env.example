# Cloudflare Worker API base URL
# Local dev: started by `wrangler dev --remote` (see worker/README.md)
NUXT_PUBLIC_WORKER_BASE_URL=http://127.0.0.1:8787

# Firebase web app config (Firebase Console -> Project settings -> Your apps -> SDK setup and config)
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
